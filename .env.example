# .env.example
# Copy to .env and fill in real values — never commit .env
#
# Usage:
#   cp .env.example .env
#   docker compose --profile dev up

# ── ROS 2 Configuration ───────────────────────────────────────────────────
# Isolates DDS discovery from other ROS 2 instances on the same machine/LAN
ROS_DOMAIN_ID=42

# ── Workstation Identity ──────────────────────────────────────────────────
# Unique identifier for this workstation cell (used in traceability events)
WORKSTATION_ID=dev-workstation-01

# ── MongoDB Connection ────────────────────────────────────────────────────
# Dev: local MongoDB sidecar (default, no change needed for dev profile)
MONGO_URI=mongodb://localhost:27017

# Prod: Azure Cosmos DB for MongoDB API
# MONGO_URI=mongodb://<account>.mongo.cosmos.azure.com:10255/?ssl=true&replicaSet=globaldb&...
