{
  "name": "Workstation",
  "build": {
    "dockerfile": "../docker/Dockerfile",
    "context": "..",
    "options": [
      "--network=host"
    ]
  },
  "workspaceFolder": "/workspaces/movement_controller",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/movement_controller,type=bind,consistency=cached",
  "runArgs": [
    "--net=host",
    "--pid=host",
    "--ipc=host"
  ],
  "containerEnv": {
    "ROS_DOMAIN_ID": "42",
    "ROS_AUTOMATIC_DISCOVERY_RANGE": "LOCALHOST",
    "RCUTILS_LOGGING_USE_STDOUT": "0"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance",
        "ms-iot.vscode-ros",
        "ms-vscode-remote.remote-containers",
        "ms-azuretools.vscode-docker",
        "github.copilot-chat"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/opt/venv/bin/python3",
        "python.analysis.extraPaths": [
          "${workspaceFolder}/install/lib/python3.12/site-packages",
          "${workspaceFolder}/install/lib/python3/site-packages"
        ],
        "editor.formatOnSave": true,
        "editor.rulers": [
          100
        ],
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff"
        }
      }
    }
  },
  "postCreateCommand": "bash /workspaces/movement_controller/docker/startup.sh"
}